<?php /** @var Mageaustralia_Preorder_Block_Button $this */ ?>
<?php if ($this->isPreorder() && ($product = $this->getProduct()) && $product->isSaleable()): ?>
    <?php if ($msg = $this->getMessage()): ?>
        <p class="mageaustralia-preorder-cta__message"><?php echo $this->escapeHtml($msg); ?></p>
    <?php endif; ?>
    <script type="text/javascript">
        // Repaint the existing .add-to-cart .btn-cart with our preorder label
        // and styling, instead of rendering a sibling button. Keeps the
        // qty + button + wishlist row layout intact (no flex/sizing drift).
        (function () {
            var label = <?php echo json_encode($this->getButtonText(), JSON_UNESCAPED_SLASHES); ?>;
            var scope = document.querySelector('.add-to-cart, .product-shop, .product-essential') || document;
            scope.querySelectorAll('button.btn-cart').forEach(function (btn) {
                btn.classList.add('mageaustralia-preorder-cta__btn');
                btn.title = label;
                var inner = btn.querySelector('span span') || btn.querySelector('span');
                if (inner) {
                    inner.textContent = label;
                } else {
                    btn.textContent = label;
                }
            });
        })();
    </script>
<?php endif; ?>
